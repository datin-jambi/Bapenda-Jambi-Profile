generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int        @id @default(autoincrement())
  uptdId       Int?
  role         Role       @default(Editor)
  name         String
  email        String     @unique
  passwordHash String
  phone        String?
  avatarUrl    String?
  gender       String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  auditLogs       AuditLog[]
  faqsAuthored    Faq[]      @relation("FaqAuthor")
  faqsUpdated     Faq[]      @relation("FaqUpdatedBy")
  galleries       Gallery[]
  news            News[]
  uptd            Uptd?      @relation(fields: [uptdId], references: [id])

  @@map("users")
}

model Uptd {
  id               Int       @id @default(autoincrement())
  code             String    @unique
  name             String
  description      String?
  address          String?
  phone            String?
  email            String?
  headName         String?

  // Wilayah
  province         String?   @default("Jambi")
  city             String?
  district         String?
  subDistrict      String?
  postalCode       String?

  // Geolokasi
  latitude         Float?
  longitude        Float?
  googleMapsUrl    String?

  // Visibilitas
  isActive         Boolean   @default(true)
  showOnPublicMap  Boolean   @default(false)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?
  users            User[]

  @@map("uptds")
}

model NewsCategory {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  news      News[]

  @@map("news_categories")
}

model News {
  id             Int           @id @default(autoincrement())
  categoryId     Int
  authorId       Int
  title          String
  slug           String        @unique
  excerpt        String?
  content        String
  thumbnailUrl   String?
  status         ContentStatus @default(DRAFT)
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  author         User          @relation(fields: [authorId], references: [id])
  category       NewsCategory  @relation(fields: [categoryId], references: [id])

  @@map("news")
}

model Gallery {
  id          Int           @id @default(autoincrement())
  authorId    Int
  title       String
  description String?
  coverImage  String?
  status      ContentStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  author      User          @relation(fields: [authorId], references: [id])
  items       GalleryItem[]

  @@map("galleries")
}

model GalleryItem {
  id          Int       @id @default(autoincrement())
  galleryId   Int
  mediaType   MediaType @default(IMAGE)
  fileUrl     String
  title       String?
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  gallery     Gallery   @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@map("gallery_items")
}

model FaqCategory {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  faqs        Faq[]

  @@map("faq_categories")
}

model Faq {
  id          Int         @id @default(autoincrement())
  categoryId  Int
  authorId    Int
  updatedById Int?
  question    String
  slug        String      @unique
  answer      String
  sortOrder   Int         @default(0)
  isPublished Boolean     @default(false)
  viewCount   Int         @default(0)
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  author      User        @relation("FaqAuthor", fields: [authorId], references: [id])
  updatedBy   User?       @relation("FaqUpdatedBy", fields: [updatedById], references: [id])
  category    FaqCategory @relation(fields: [categoryId], references: [id])

  @@index([slug])
  @@index([categoryId])
  @@index([isPublished])
  @@map("faqs")
}

model Page {
  id             Int       @id @default(autoincrement())
  title          String
  slug           String    @unique
  content        String
  seoTitle       String?
  seoDescription String?
  isPublished    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@map("pages")
}

model Banner {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String
  buttonText  String?
  buttonUrl   String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("banners")
}

model Regulation {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@map("regulations")
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  entityType String
  entityId   Int
  oldData    Json?
  newData    Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

enum Role {
  Super_Admin
  Admin
  Editor
  Ketua_Uptd
  Admin_Uptd
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

enum MediaType {
  IMAGE
  VIDEO
  PDF
}
